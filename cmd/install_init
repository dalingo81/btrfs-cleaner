#!/bin/bash
set -e

# === Python 3 ===
PYTHON=""
for p in python3.11 python3.10 python3 python; do
    if command -v $p &>/dev/null; then
        PYTHON=$(command -v $p)
        break
    fi
done

if [ -z "$PYTHON" ]; then
    echo "Python 3 required, attempting to install..." > "${TRIM_TEMP_LOGFILE}"
    apt-get update -qq && apt-get install -y -qq python3 python3-pip 2>/dev/null || true
    if ! command -v python3 &>/dev/null; then
        echo "Python 3 could not be installed." > "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi
    PYTHON=$(command -v python3)
fi
echo "Python found: $($PYTHON --version)"

# === btrfs-progs ===
if ! command -v btrfs &>/dev/null; then
    echo "Installing btrfs-progs..." > "${TRIM_TEMP_LOGFILE}"
    apt-get update -qq && apt-get install -y -qq btrfs-progs 2>/dev/null || {
        echo "btrfs-progs could not be installed." > "${TRIM_TEMP_LOGFILE}"
        exit 1
    }
fi

# === curl (required by proxy.cgi) ===
if ! command -v curl &>/dev/null; then
    echo "Installing curl..."
    apt-get install -y -qq curl 2>/dev/null || true
fi

# === pip ===
if ! ${PYTHON} -m pip --version &>/dev/null; then
    echo "Installing pip..."
    apt-get install -y -qq python3-pip 2>/dev/null || true
    # Fallback: use ensurepip
    if ! ${PYTHON} -m pip --version &>/dev/null; then
        ${PYTHON} -m ensurepip --upgrade 2>/dev/null || true
    fi
fi

# === sudoers for passwordless btrfs (install_callback handles this but we check early) ===
mkdir -p /etc/sudoers.d 2>/dev/null || true

echo "Prerequisites verified."
exit 0
